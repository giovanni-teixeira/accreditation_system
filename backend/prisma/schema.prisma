enum TipoCategoria {
  EXPOSITOR
  VISITANTE
  PRODUTOR
  IMPRENSA
  ORGANIZACAO
  TERCEIRIZADO
}

enum PerfilAcesso {
  LEITOR_CATRACA
  ADMIN
}

enum TipoCombustivel {
  GASOLINA
  ETANOL
  DIESEL
  ELETRICO
}

model Evento {
  id           String        @id @default(uuid()) @db.Uuid
  nomeEvento   String        @unique @map("nome_evento")
  isGratuito   Boolean       @default(true) @map("is_gratuito")
  localEvento  String?       @map("local_evento")
  latitude     Float?        @map("latitude")
  longitude    Float?        @map("longitude")
  privateKey   String?       @map("private_key")
  publicKey    String?       @map("public_key")
  credenciados Credenciado[]

  @@map("evento")
}

model UsuarioOrganizacao {
  id           String       @id @default(uuid()) @db.Uuid
  login        String       @unique
  senhaHash    String       @map("senha_hash")
  perfilAcesso PerfilAcesso @map("perfil_acesso")
  setor        String?      @map("setor")

  @@map("usuario_organizacao")
}

model Credenciado {
  id              String          @id @default(uuid()) @db.Uuid
  eventoId        String          @map("evento_id") @db.Uuid
  tipoCategoria   TipoCategoria   @map("tipo_categoria")
  nomeCompleto    String          @map("nome_completo")
  cpf             String          @unique
  rg              String
  celular         String
  email           String
  cnpj            String?
  ccir            String?
  nomeEmpresa     String?         @map("nome_empresa")
  siteEmpresa     String?         @map("site_empresa")
  aceiteLgpd      Boolean         @map("aceite_lgpd")

  evento          Evento           @relation(fields: [eventoId], references: [id], onDelete: Restrict)
  endereco        Endereco?
  credencial      Credencial?
  descarbonizacao Descarbonizacao?

  @@unique([eventoId, cpf])
  @@index([eventoId])
  @@index([email])
  @@index([tipoCategoria])
  @@map("credenciado")
}

model Endereco {
  id            String @id @default(uuid()) @db.Uuid
  credenciadoId String @unique @map("credenciado_id") @db.Uuid
  cep           String
  rua           String
  bairro        String
  cidade        String
  estado        String
  pais          String @default("Brasil")
  latitude      Float?
  longitude     Float?

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)

  @@map("endereco")
}

model EnderecoCache {
  id         String   @id @default(uuid()) @db.Uuid
  cep        String   @unique
  pais       String   @default("Brasil")
  rua        String
  bairro     String
  cidade     String
  estado     String
  latitude   Float?
  longitude  Float?
  atualizado DateTime @default(now()) @updatedAt

  @@map("endereco_cache")
}

model Descarbonizacao {
  id                  String          @id @default(uuid()) @db.Uuid
  credenciadoId       String          @unique @map("credenciado_id") @db.Uuid
  distanciaIdaVoltaKm Float           @map("distancia_ida_volta_km")
  tipoCombustivel     TipoCombustivel @map("tipo_combustivel")
  latitudeOrigem      Float?          @map("latitude_origem")
  longitudeOrigem     Float?          @map("longitude_origem")
  pegadaCo2           Float?          @map("pegada_co2_kg")

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)

  @@map("descarbonizacao")
}

model Credencial {
  id            String   @id @default(uuid()) @db.Uuid
  credenciadoId String   @unique @map("credenciado_id") @db.Uuid
  ticketId      String   @unique @default(uuid()) @map("ticket_id") @db.Uuid
  qrToken       String   @map("qr_token") @db.Text
  downloads     Int      @default(0)
  printCount    Int      @default(0) @map("print_count")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)
  scans       QrScan[]

  @@index([ticketId])
  @@map("credencial")
}

model QrScan {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  scannerId String   @map("scanner_id")
  scanType  String   @map("scan_type")
  createdAt DateTime @default(now()) @map("created_at")

  credencial Credencial @relation(fields: [ticketId], references: [ticketId], onDelete: Cascade)

  @@index([ticketId])
  @@map("qrscans")
}
