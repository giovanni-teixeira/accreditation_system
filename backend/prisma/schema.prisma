// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoCategoria {
  EXPOSITOR
  VISITANTE
  PRODUTOR
  IMPRENSA
  ORGANIZACAO
  TERCEIRIZADO
}

enum PerfilAcesso {
  LEITOR_CATRACA
  ADMIN
}

enum TipoCombustivel {
  GASOLINA
  ETANOL
  DIESEL
  ELETRICO
}

model Evento {
  id           String        @id @db.VarChar(5) @default(dbgenerated("generate_short_id()"))
  nomeEvento   String        @unique @map("nome_evento")
  isGratuito   Boolean       @default(true) @map("is_gratuito")
  localEvento  String?       @map("local_evento")
  latitude     Float?        @map("latitude")
  longitude    Float?        @map("longitude")
  privateKey   String?       @map("private_key")
  publicKey    String?       @map("public_key")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  credenciados Credenciado[]

  @@map("evento")
}

model UsuarioOrganizacao {
  id           String       @id @db.VarChar(5) @default(dbgenerated("generate_short_id()"))
  login        String       @unique
  senhaHash    String       @map("senha_hash")
  perfilAcesso PerfilAcesso @map("perfil_acesso")
  setor        String?      @map("setor")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("usuario_organização")
}

model Credenciado {
  id              String        @id @db.VarChar(5) @default(dbgenerated("generate_short_id()"))
  eventoId        String        @map("evento_id") @db.VarChar(5)
  tipoCategoria   TipoCategoria @map("tipo_categoria")
  nomeCompleto    String        @map("nome_completo")
  cpf             String        @unique
  rg              String?
  celular         String
  email           String
  cnpj            String?
  ccir            String?
  nomeEmpresa     String?       @map("nome_empresa")
  siteEmpresa     String?       @map("site_empresa")
  nomePropriedade String?       @map("nome_propriedade")
  nomeVeiculo     String?       @map("nome_veiculo")
  aceiteLgpd      Boolean       @map("aceite_lgpd")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  evento          Evento           @relation(fields: [eventoId], references: [id], onDelete: Restrict)
  endereco        Endereco?
  credencial      Credencial?
  descarbonizacao Descarbonizacao?

  @@unique([eventoId, cpf])
  @@index([eventoId])
  @@index([email])
  @@index([tipoCategoria])
  @@map("credenciado")
}

model Endereco {
  id            String @id @db.VarChar(5) @default(dbgenerated("generate_short_id()"))
  credenciadoId String @unique @map("credenciado_id") @db.VarChar(5)
  cep           String?
  rua           String?
  bairro        String?
  cidade        String
  estado        String
  pais          String @default("Brasil")
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)

  @@map("endereco")
}

model EnderecoCache {
  id         String   @id @db.VarChar(5) @default(dbgenerated("generate_short_id()"))
  cep        String   @unique
  pais       String   @default("Brasil")
  rua        String
  bairro     String
  cidade     String
  estado     String
  latitude   Float?
  longitude  Float?
  atualizado DateTime @default(now()) @updatedAt
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("endereco_cache")
}

model Descarbonizacao {
  id                  String          @id @db.VarChar(5) @default(dbgenerated("generate_short_id()"))
  credenciadoId       String          @unique @map("credenciado_id") @db.VarChar(5)
  distanciaIdaVoltaKm Float           @map("distancia_ida_volta_km")
  tipoCombustivel     TipoCombustivel @map("tipo_combustivel")
  latitudeOrigem      Float?          @map("latitude_origem")
  longitudeOrigem     Float?          @map("longitude_origem")
  pegadaCo2           Float?          @map("pegada_co2_kg")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)

  @@map("descarbonizacao")
}

model Credencial {
  id            String   @id @db.VarChar(5) @default(dbgenerated("generate_short_id()"))
  credenciadoId String   @unique @map("credenciado_id") @db.VarChar(5)
  ticketId      String   @unique @map("ticket_id")
  qrToken       String   @map("qr_token") @db.Text
  downloads     Int      @default(0)
  printCount    Int      @default(0) @map("print_count")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)
  scans       QrScan[]

  @@index([ticketId])
  @@map("credencial")
}

model QrScan {
  id        String   @id @db.VarChar(5) @default(dbgenerated("generate_short_id()"))
  ticketId  String   @map("ticket_id")
  scannerId String   @map("scanner_id")
  scanType  String   @map("scan_type")
  createdAt DateTime @default(now()) @map("created_at")

  credencial Credencial @relation(fields: [ticketId], references: [ticketId], onDelete: Cascade)

  @@index([ticketId])
  @@map("qrscans")
}
