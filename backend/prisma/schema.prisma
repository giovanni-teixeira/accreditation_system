enum TipoCategoria {
  EXPOSITOR
  VISITANTE
  CAFEICULTOR
  IMPRENSA
  ORGANIZACAO
  TERCEIRIZADO
}

enum PerfilAcesso {
  LEITOR_CATRACA
  ADMIN
}

enum TipoCombustivel {
  GASOLINA
  ETANOL
  DIESEL
  ELETRICO
}

model Evento {
  id           String        @id @default(uuid()) @db.Uuid
  nomeEvento   String        @unique @map("nome_evento")
  isGratuito   Boolean       @default(true) @map("is_gratuito")
  credenciados Credenciado[]

  @@map("evento")
}

model UsuarioOrganizacao {
  id           String       @id @default(uuid()) @db.Uuid
  login        String       @unique
  senhaHash    String       @map("senha_hash")
  perfilAcesso PerfilAcesso @map("perfil_acesso")

  @@map("usuario_organizacao")
}

model Credenciado {
  id            String        @id @default(uuid()) @db.Uuid
  eventoId      String        @map("evento_id") @db.Uuid
  tipoCategoria TipoCategoria @map("tipo_categoria")
  nomeCompleto  String        @map("nome_completo")
  cpf           String        @unique
  rg            String
  celular       String
  email         String
  cnpj          String?
  ccir          String?
  aceiteLgpd    Boolean         @map("aceite_lgpd")
  tipoCombustivel TipoCombustivel @map("tipo_combustivel")

  evento          Evento           @relation(fields: [eventoId], references: [id], onDelete: Restrict)
  endereco        Endereco?
  credencial      Credencial?
  descarbonizacao Descarbonizacao?

  @@unique([eventoId, cpf])
  @@index([eventoId])
  @@index([email])
  @@index([tipoCategoria])
  @@map("credenciado")
}

model Endereco {
  id            String      @id @default(uuid()) @db.Uuid
  credenciadoId String      @unique @map("credenciado_id") @db.Uuid
  cep           String
  rua           String
  bairro        String
  cidade        String
  estado        String

  credenciado   Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)

  @@map("endereco")
}

model Descarbonizacao {
  id                  String          @id @default(uuid()) @db.Uuid
  credenciadoId       String          @unique @map("credenciado_id") @db.Uuid
  distanciaIdaVoltaKm Float           @map("distancia_ida_volta_km")
  tipoCombustivel     TipoCombustivel @map("tipo_combustivel")

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)

  @@map("descarbonizacao")
}

model Credencial {
  id                 String  @id @default(uuid()) @db.Uuid
  credenciadoId      String  @unique @map("credenciado_id") @db.Uuid
  hashQrCode         String  @map("hash_qr_code")
  hashCodigoBarras   String  @map("hash_codigo_barras")
  isImpressaQuiosque Boolean @default(false) @map("is_impressa_quiosque")

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)

  @@map("credencial")
}
