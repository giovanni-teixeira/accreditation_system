// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Credenciado {
  id              String   @id @default(uuid())
  nomeCompleto    String
  cpf             String   @unique
  rg              String
  celular         String
  email           String
  municipio       String
  uf              String
  aceitouLgpd     Boolean  @default(false)
  tipo            String   // Pode ser "Visitante", "Cafeicultor", "Expositor", "Imprensa"
  criadoEm        DateTime @default(now())

  // Campos específicos de cada tipo
  // Expositores
  cnpj            String?
  nomeEmpresa     String?
  siteEmpresa     String?

  // Cafeicultores
  ccir            String?
  nomePropriedade String?

  // Imprensa (cnpj e siteEmpresa já contemplados acima)
  nomeVeiculo     String?
}
